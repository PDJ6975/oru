model Habit {
    id Int @id @default(autoincrement())
    icon String
    type HabitType
    dailyGoal Decimal?
    note String?
    status HabitStatus
    unit Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId Int
    unitId Int?
    // scheduledDays
    // creationDate
    // startDate
    // archivedDate
}
enum HabitType {
    BOOLEAN
    QUANTITY
}
enum HabitStatus {
    ACTIVE
    CONSOLIDATED
    ARCHIVED
}
